<?xml version="1.0" encoding="utf-8"?>

   <androidx.constraintlayout.widget.ConstraintLayout
       xmlns:android="http://schemas.android.com/apk/res/android"
       xmlns:app="http://schemas.android.com/apk/res-auto"
       xmlns:tools="http://schemas.android.com/tools"
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       >

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.25"
        android:id="@+id/fragment_quick_scan_guideline_1"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.75"
        android:id="@+id/fragment_quick_scan_guideline_2"
        />
 <androidx.constraintlayout.widget.Guideline
     android:layout_width="match_parent"
     android:layout_height="match_parent"
     android:orientation="vertical"
     app:layout_constraintGuide_percent="0.5"
     android:id="@+id/fragment_quick_scan_guideline_3"
     />
    <LinearLayout
        android:id="@+id/iv_bpm_value"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@drawable/ic_red_circle_bg"
        app:layout_constraintEnd_toStartOf="@id/fragment_quick_scan_guideline_2"
        app:layout_constraintStart_toEndOf="@+id/fragment_quick_scan_guideline_1"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" >

    <TextView
        android:id="@+id/fragment_quick_scan_bpm_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_58ssp"
        android:textStyle="bold"
         />

    <TextView
        android:id="@+id/txt_bpm_lbl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="bpm"
        android:textAllCaps="true"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_16ssp"
        app:layout_constraintLeft_toLeftOf="@id/iv_bpm_value"
        app:layout_constraintRight_toRightOf="@id/iv_bpm_value"
        app:layout_constraintTop_toBottomOf="@+id/fragment_quick_scan_bpm_value" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/iv_spo_value"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_width="0dp"
        android:orientation="vertical"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:background="@drawable/ic_green_circle_bg"
        app:layout_constraintEnd_toStartOf="@id/fragment_quick_scan_guideline_2"
        app:layout_constraintStart_toEndOf="@+id/fragment_quick_scan_guideline_1"
        app:layout_constraintTop_toBottomOf="@id/iv_bpm_value"
        tools:ignore="ContentDescription">

    <TextView
        android:id="@+id/fragment_quick_scan_spo_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_58ssp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_spo_value"
        app:layout_constraintLeft_toLeftOf="@id/iv_spo_value"
        app:layout_constraintRight_toRightOf="@id/iv_spo_value"
        app:layout_constraintTop_toTopOf="@id/iv_spo_value" />

    <TextView
        android:id="@+id/txt_spo_lbl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SPO2"
        android:textAllCaps="true"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_16ssp"
        app:layout_constraintLeft_toLeftOf="@id/fragment_quick_scan_spo_value"
        app:layout_constraintRight_toRightOf="@id/fragment_quick_scan_spo_value"
        app:layout_constraintTop_toBottomOf="@+id/fragment_quick_scan_spo_value" />
    </LinearLayout>

 <Button
     android:id="@+id/fragment_quick_scan_start_button"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_marginTop="@dimen/_50sdp"
     android:layout_marginEnd="@dimen/_13sdp"
     android:layout_marginBottom="@dimen/_20sdp"
     android:background="@drawable/button_background_low_radius"
     android:elevation="@dimen/_50sdp"
     android:paddingLeft="@dimen/_36sdp"
     android:paddingRight="@dimen/_36sdp"
     android:text="@string/btn_start"
     android:textAllCaps="true"
     android:textColor="@color/color_white"
     android:textSize="@dimen/_14ssp"
     android:textStyle="bold"
     app:layout_constraintBottom_toBottomOf="parent"
     app:layout_constraintEnd_toStartOf="@+id/fragment_quick_scan_guideline_3"
     app:layout_constraintHorizontal_bias="1.0"
     app:layout_constraintStart_toStartOf="parent"
     app:layout_constraintTop_toBottomOf="@+id/iv_spo_value"
     app:layout_constraintVertical_bias="1.0" />

 <Button
     android:id="@+id/fragment_quick_scan_stop_button"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_marginStart="@dimen/_13sdp"
     android:layout_marginTop="@dimen/_50sdp"
     android:background="@drawable/button_background_low_radius_disable"
     android:elevation="@dimen/_50sdp"
     android:paddingLeft="@dimen/_36sdp"
     android:paddingRight="@dimen/_36sdp"
     android:text="@string/btn_stop"
     android:textAllCaps="true"
     android:textColor="@color/color_white"
     android:textSize="@dimen/_14ssp"
     android:textStyle="bold"
     app:layout_constraintBottom_toBottomOf="@+id/fragment_quick_scan_start_button"
     app:layout_constraintEnd_toEndOf="parent"
     app:layout_constraintHorizontal_bias="0.0"
     app:layout_constraintStart_toStartOf="@+id/fragment_quick_scan_guideline_3"
     app:layout_constraintTop_toBottomOf="@+id/iv_spo_value"
     app:layout_constraintVertical_bias="1.0" />
   </androidx.constraintlayout.widget.ConstraintLayout>
