<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/fragment_bpm_cardview_total_time_sleep"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/_5jdp"
        app:cardBackgroundColor="@color/button_disabled_color"
        app:cardCornerRadius="@dimen/_6jdp"
        app:cardElevation="@dimen/_5jdp"
        app:cardUseCompatPadding="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="@dimen/_15jdp">

            <TextView
                android:id="@+id/row_bpm_data_list_txt_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_3jdp"
                android:gravity="left"
                android:text="@string/tital_bpm_activity"
                android:textColor="@color/color_white"
                android:textSize="@dimen/_15ssp" />

            <TextView
                android:id="@+id/row_bpm_data_list_txt_start_stop_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_3jdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="left"
                android:layout_below="@+id/row_bpm_data_list_txt_name"
                android:textColor="@color/color_white"
                android:textSize="@dimen/_14ssp" />

            <ImageView
                android:id="@+id/custom_device_list_row_img_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/icon_history_arrow"
                android:layout_marginRight="@dimen/_5jdp"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>