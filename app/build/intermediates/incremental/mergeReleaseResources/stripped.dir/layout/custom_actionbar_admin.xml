<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/custom_actionbar_main_layout"
    android:layout_width="match_parent"
    android:padding="@dimen/_8sdp"
    android:layout_height="@dimen/_40sdp">

    <RelativeLayout
        android:id="@+id/custom_actionbar_user_relative_left_side"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/_10sdp">

        <ImageView
            android:focusable="false"
            android:id="@+id/custom_actionbar_admin_imageview_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:padding="@dimen/_5sdp"
            tools:ignore="ContentDescription"
            android:src="@drawable/ic_back"
             />

        <ImageView
            android:id="@+id/custom_actionbar_admin_imageview_drawer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:padding="@dimen/_5sdp"
            tools:ignore="ContentDescription"
            android:src="@drawable/icon_menu"
            android:visibility="gone" />
    </RelativeLayout>

    <TextView
        android:focusable="false"
        android:id="@+id/custom_actionbar_admin_textview_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_centerInParent="true"
        android:ellipsize="end"
        android:gravity="left"
        android:text=""
        android:textColor="@color/color_white"
        android:textSize="@dimen/_14ssp"
        tools:ignore="RtlHardcoded" />


    <ImageView
        android:id="@+id/custom_actionbar_admin_imageview_add_story"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:focusable="false"
        android:src="@drawable/ic_history_pink"
        android:visibility="invisible"
        tools:ignore="ContentDescription"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/custom_actionbar_admin_imageview_right_drawer_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:focusable="false"

        android:paddingTop="@dimen/_4sdp"
        android:paddingBottom="@dimen/_4sdp"
        android:paddingEnd="@dimen/_5sdp"
        android:scaleType="fitEnd"
        android:src="@drawable/ic_menu_pink"
        android:visibility="gone"
        tools:ignore="ContentDescription"
        tools:visibility="visible" />


</RelativeLayout>