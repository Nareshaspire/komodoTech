    <LinearLayout
        android:id="@+id/fragment_sleep_relative_connect_disconnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/fragment_sleep_bottombar"
        android:layout_marginBottom="@dimen/_10sdp"
        android:layout_marginLeft="@dimen/_5sdp"
        android:layout_marginRight="@dimen/_5sdp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/fragment_sleep_button_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_10sdp"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_weight="1"
            android:background="@drawable/button_background_enabled"
            android:gravity="center"
            android:text="@string/btn_start"
            android:textAllCaps="false"
            android:textColor="@color/color_white"
            android:textSize="@dimen/_16ssp" />

        <Button
            android:id="@+id/fragment_sleep_button_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_10sdp"
            android:layout_marginRight="@dimen/_10sdp"
            android:layout_toRightOf="@+id/fragment_sleep_button_start"
            android:layout_weight="1"
            android:background="@drawable/button_background_disabled"
            android:gravity="center"
            android:text="@string/btn_stop"
            android:textAllCaps="false"
            android:textColor="@color/button_enabled_color"
            android:textSize="@dimen/_16ssp" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/fragment_sleep_bottombar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/button_enabled_color"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/activity_main_linear_tab_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_3sdp"
                android:paddingTop="@dimen/_3sdp">

                <ImageView
                    android:id="@+id/activity_main_imageview_home"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:src="@drawable/icon_home_selected" />

                <TextView
                    android:id="@+id/activity_main_textview_home"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/tital_home"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_10ssp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/activity_main_linear_bpm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_3sdp"
                android:paddingTop="@dimen/_3sdp">

                <ImageView
                    android:id="@+id/activity_main_imageview_bpm"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:src="@drawable/icon_bpm_selected" />

                <TextView
                    android:id="@+id/activity_main_textview_bpm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/tital_bpm"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_10ssp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/activity_main_linear_tab_hrv"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_3sdp"
                android:paddingTop="@dimen/_3sdp">

                <ImageView
                    android:id="@+id/activity_main_imageview_hrv"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:src="@drawable/icon_ecg_selected" />

                <TextView
                    android:id="@+id/activity_main_textview_hrv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:lines="1"
                    android:text="@string/tital_ecg_hrv"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_10ssp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/activity_main_linear_tab_setting"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_3sdp"
                android:paddingTop="@dimen/_3sdp">

                <ImageView
                    android:id="@+id/activity_main_imageview_setting"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:src="@drawable/icon_setting_selected" />

                <TextView
                    android:id="@+id/activity_main_textview_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:lines="1"
                    android:text="@string/tital_setting"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_10ssp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>