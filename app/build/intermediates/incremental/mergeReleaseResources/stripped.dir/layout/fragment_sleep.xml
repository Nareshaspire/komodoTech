<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/icon_bg">

    <RelativeLayout
        android:id="@+id/fragment_sleep_main_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40sdp"
        android:layout_alignParentTop="true"
        android:background="@color/custom_header_color"
        android:padding="@dimen/_8sdp">

        <ImageView
            android:id="@+id/fragment_sleep_imageview_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/_10sdp"
            android:focusable="false"
            android:padding="@dimen/_5sdp"
            android:src="@drawable/icon_back"
            android:visibility="visible" />

        <TextView
            android:id="@+id/fragment_sleep_textview_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:ellipsize="end"
            android:focusable="false"
            android:gravity="left"
            android:text="@string/tital_sleep"
            android:textColor="@color/color_white"
            android:textSize="@dimen/_14ssp" />

        <ImageView
            android:id="@+id/fragment_sleep_imageview_add_story"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:focusable="false"
            android:padding="@dimen/_5sdp"
            android:src="@drawable/icon_history"
            android:visibility="visible" />

    </RelativeLayout>


    <RelativeLayout
        android:id="@+id/fragment_bpm_relative_chart_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/fragment_sleep_relative_total_sleep"
        android:layout_below="@+id/fragment_sleep_main_layout"
        android:layout_marginLeft="@dimen/_5sdp"
        android:layout_marginRight="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:gravity="center"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/fragment_sleep_cardview_bpm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="@dimen/_5sdp"
            app:cardBackgroundColor="@color/cardview_background"
            app:cardCornerRadius="@dimen/_4sdp"
            app:cardElevation="@dimen/_4sdp"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/fragment_sleep_line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:background="@color/button_enabled_color" />

                <TextView
                    android:id="@+id/fragment_sleep_txt_start_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginLeft="@dimen/_55ssp"
                    android:padding="@dimen/_3sdp"
                    android:text=""
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_12sdp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/fragment_sleep_txt_end_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:padding="@dimen/_3sdp"
                    android:text=""
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/_12sdp"
                    android:textStyle="bold" />



            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/fragment_sleep_chart_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@anim/spinner"
            android:elevation="@dimen/_5sdp"
            android:visibility="gone" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/fragment_sleep_relative_total_sleep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/fragment_sleep_relative_connect_disconnect"
        android:layout_marginLeft="@dimen/_10sdp"
        android:layout_marginRight="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp">

        <TextView
            android:id="@+id/fragment_sleep_txt_awake"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/blue_circle"
            android:gravity="center"
            android:text="@string/label_awake"
            android:textColor="@color/color_black"
            android:layout_marginLeft="@dimen/_25sdp"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/fragment_sleep_txt_lighter"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/red_circle"
            android:gravity="center"
            android:text="@string/label_lighter"
            android:layout_centerHorizontal="true"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/fragment_sleep_txt_light"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/green_circle"
            android:gravity="center"
            android:text="@string/label_light"
            android:layout_alignParentRight="true"
            android:layout_marginRight="@dimen/_25sdp"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/fragment_sleep_txt_deeper"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/red_circle"
            android:gravity="center"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginLeft="@dimen/_25sdp"
            android:layout_below="@+id/fragment_sleep_txt_awake"
            android:text="@string/label_deeper"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_10ssp" />


        <TextView
            android:id="@+id/fragment_sleep_txt_deep"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/green_circle"
            android:gravity="center"
            android:text="@string/label_deep"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_below="@+id/fragment_sleep_txt_awake"
            android:layout_centerHorizontal="true"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/fragment_sleep_txt_total_min"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/blue_circle"
            android:gravity="center"
            android:text="@string/label_total_min"
            android:layout_alignParentRight="true"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginRight="@dimen/_25sdp"
            android:layout_below="@+id/fragment_sleep_txt_awake"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_10ssp" />

    </RelativeLayout>

