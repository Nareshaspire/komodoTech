<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/_19sdp"
    >
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/raw_health_history_ecg_item_main_cl"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true"
    android:paddingBottom="@dimen/_13sdp"
    android:layout_marginStart="@dimen/_16sdp"
    android:layout_marginEnd="@dimen/_16sdp"
    android:background="@drawable/button_background_rounded_dark_blue">

    <TextView
        android:id="@+id/raw_health_history_ecg_item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_11sdp"
        android:layout_marginTop="@dimen/_11sdp"
        android:text="@string/tital_ecg_activity"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_16ssp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/raw_health_history_ecg_item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_5sdp"
        android:textColor="@color/color_gray_5"
        android:textSize="@dimen/_11ssp"
        app:layout_constraintStart_toStartOf="@+id/raw_health_history_ecg_item_title"
        app:layout_constraintTop_toBottomOf="@+id/raw_health_history_ecg_item_title"
        tools:text="09:27:33 - 09:44:25" />

    <ImageView
        android:id="@+id/raw_health_history_ecg_item_arrow"
        android:layout_width="@dimen/_9sdp"
        android:layout_height="@dimen/_16sdp"
        android:layout_marginEnd="@dimen/_13sdp"
        android:scaleType="fitXY"
        android:src="@drawable/icon_history_arrow"
        android:tint="@color/color_sky_blue"
        app:layout_constraintBottom_toBottomOf="@+id/raw_health_history_ecg_item_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/raw_health_history_ecg_item_title" />
</androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>

