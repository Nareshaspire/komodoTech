<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_white"
    android:gravity="center">

    <TextView
        android:id="@+id/activity_login_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:gravity="center"
        android:text="@string/activity_login"
        android:visibility="gone"
        android:textColor="@color/color_white"
        android:textSize="@dimen/_14ssp" />

    <ImageView
        android:id="@+id/activity_login_imageview_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/_60sdp"
        android:src="@drawable/ic_logo"
        tools:ignore="ContentDescription" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/activity_login_imageview_logo"
        android:layout_marginTop="@dimen/_65sdp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/activity_login_edittext_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_20sdp"
            android:layout_marginRight="@dimen/_20sdp"
            android:background="@drawable/custom_edittext_background_login_signup"
            android:drawableStart="@drawable/ic_username"
            android:drawablePadding="@dimen/_8sdp"
            android:ellipsize="end"
            android:gravity="center"
            android:hint="@string/text_login_email"
            android:imeOptions="actionNext"
            android:text=""
            android:inputType="textEmailAddress"
            android:lines="1"
            android:paddingStart="@dimen/_12sdp"
            android:paddingTop="@dimen/_12sdp"
            android:paddingEnd="@dimen/_25sdp"
            android:paddingBottom="@dimen/_12sdp"
            android:textSize="@dimen/_14ssp" />

        <EditText
            android:id="@+id/activity_login_edittext_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_20sdp"
            android:layout_marginRight="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:gravity="center"
            android:background="@drawable/custom_edittext_background_login_signup"
            android:drawableStart="@drawable/ic_password"
            android:drawablePadding="@dimen/_8sdp"
            android:ellipsize="end"
            android:text=""
            android:hint="@string/text_login_password"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:lines="1"
            android:paddingStart="@dimen/_12sdp"
            android:paddingTop="@dimen/_12sdp"
            android:paddingEnd="@dimen/_25sdp"
            android:paddingBottom="@dimen/_12sdp"
            android:textSize="@dimen/_14ssp" />

        <Button
            android:focusable="false"
            android:id="@+id/activity_login_button_signin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_20sdp"
            android:layout_marginRight="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_58sdp"
            android:background="@drawable/button_background_login"
            android:elevation="@dimen/_50sdp"
            android:text="@string/text_login_button_signin"
            android:padding="@dimen/_12sdp"
            android:textAllCaps="false"
            android:textColor="@color/color_white"
            android:textSize="@dimen/_14ssp" />

        <TextView
            android:focusable="false"
            android:id="@+id/activity_login_textview_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_10sdp"
            android:gravity="center"
            android:padding="@dimen/_8sdp"
            android:text="@string/text_login_forgot_password_textview_label"
            android:textColor="@color/sky_color"
            android:textSize="@dimen/_14ssp" />
    </LinearLayout>

    <TextView
        android:focusable="false"
        android:id="@+id/activity_login_textview_sign_up"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:padding="@dimen/_10sdp"
        android:text="@string/txt_no_account"
        android:textColor="@color/txt_register_color"
        android:textSize="@dimen/_12ssp" />
</RelativeLayout>