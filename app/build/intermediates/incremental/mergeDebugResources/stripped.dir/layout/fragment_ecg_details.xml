<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/color_white">

    <RelativeLayout
        android:id="@+id/fragment_ecg_details_main_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40sdp"

        android:layout_alignParentTop="true"
        android:padding="@dimen/_8sdp">


        <ImageView
            android:id="@+id/fragment_ecg_details_imageview_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/_10sdp"
            android:focusable="false"
            android:padding="@dimen/_5sdp"
            android:src="@drawable/ic_back"
            android:visibility="visible"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/fragment_ecg_details_textview_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:ellipsize="end"
            android:focusable="false"
            android:gravity="center"
            android:text="@string/tital_ecg_details"
            android:textColor="@color/toolbar_bg_color"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />


    </RelativeLayout>


    <androidx.cardview.widget.CardView
        android:id="@+id/fragment_ecg_cardview_bpm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/fragment_ecg_linearlayout_data_indicatiors"
        android:layout_below="@+id/fragment_ecg_details_main_layout"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:paddingStart="@dimen/_5sdp"
        android:paddingTop="@dimen/_8sdp"
        android:paddingEnd="@dimen/_5sdp"
        android:paddingBottom="@dimen/_8sdp"
        app:cardBackgroundColor="@color/color_white"
        app:cardCornerRadius="@dimen/_17sdp"
        app:cardElevation="@dimen/_2sdp"
        app:cardUseCompatPadding="true">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/fragment_ecg_details_graph_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            />

        <ProgressBar
            android:id="@+id/fragment_ecg_details_progress_bar"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_gravity="center"
            android:elevation="@dimen/_4sdp"
            android:visibility="gone"
            tools:ignore="UnusedAttribute"
            tools:visibility="visible" />
    </androidx.cardview.widget.CardView>


    <LinearLayout
        android:id="@+id/fragment_ecg_linearlayout_data_indicatiors"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/fragment_ecg_details_linear_bottom"
        android:orientation="horizontal">

        <RelativeLayout
            android:id="@+id/fragment_ecg_relativelayout_bpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_5sdp"
            android:textAllCaps="false"
            android:textColor="@color/color_white"
            android:textSize="@dimen/_12ssp">

            <ImageView
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_80sdp"
                android:layout_centerHorizontal="true"
                android:src="@drawable/blue_circle" />

            <TextView
                android:id="@+id/fragment_ecg_details_txt_bpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="@string/tital_bpm"
                android:textColor="@color/color_black"
                android:textSize="@dimen/_12ssp" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/fragment_ecg_relativelayout_hrv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/fragment_ecg_button_start"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_5sdp"
            android:textAllCaps="false"
            android:textColor="@color/button_enabled_color"
            android:textSize="@dimen/_12ssp">

            <ImageView
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_80sdp"
                android:layout_centerHorizontal="true"
                android:src="@drawable/green_circle" />

            <TextView
                android:id="@+id/fragment_ecg_details_txt_hrv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="@string/tital_hrv"
                android:textColor="@color/color_black"
                android:textSize="@dimen/_12ssp" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/fragment_ecg_relativelayout_met"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/fragment_ecg_button_start"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_5sdp"
            android:textAllCaps="false"
            android:textColor="@color/button_enabled_color"
            android:textSize="@dimen/_12ssp">

            <ImageView
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_80sdp"
                android:layout_centerHorizontal="true"
                android:src="@drawable/red_circle" />

            <TextView
                android:id="@+id/fragment_ecg_details_txt_met"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="@string/tital_met"
                android:textColor="@color/color_black"
                android:textSize="@dimen/_12ssp" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fragment_ecg_details_linear_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/fragment_ecg_details_txt_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0\nStep"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_12ssp" />

        <View
            android:layout_width="0.8dp"
            android:layout_height="match_parent"
            android:background="@color/button_disabled_color" />

        <TextView
            android:id="@+id/fragment_ecg_details_txt_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0\nMeter"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_12ssp" />

        <View
            android:layout_width="0.8dp"
            android:layout_height="match_parent"
            android:background="@color/button_disabled_color" />

        <TextView
            android:id="@+id/fragment_ecg_details_txt_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_weight="1"
            android:gravity="center"
            android:text=""
            android:textColor="@color/color_black"
            android:textSize="@dimen/_12ssp" />

    </LinearLayout>

</RelativeLayout>


