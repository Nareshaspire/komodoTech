<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/button_enabled_color">
    <LinearLayout
        android:padding="@dimen/_10sdp"
        android:gravity="center"
        android:background="@color/color_gray_6"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textColor="@color/toolbar_bg_color"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_gravity="center"
            android:text="Feet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textColor="@color/toolbar_bg_color"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inch"/>
    </LinearLayout>
 <LinearLayout
     android:background="@color/color_white"
     android:layout_width="match_parent"
     android:orientation="horizontal"
     android:layout_height="match_parent">
     <NumberPicker
         android:paddingLeft="@dimen/_5sdp"
         android:paddingRight="@dimen/_5sdp"
         android:background="@color/color_white"
         android:id="@+id/popup_list_layout_feet_picker"
         android:layout_weight="1"
         android:layout_width="match_parent"
         android:layout_height="wrap_content">
     </NumberPicker>
     <NumberPicker
         android:paddingLeft="@dimen/_5sdp"
         android:paddingRight="@dimen/_5sdp"
         android:background="@color/color_white"
         android:id="@+id/popup_list_layout_inch_picker"
         android:layout_weight="1"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"></NumberPicker>
 </LinearLayout>
    <Button

        android:id="@+id/popup_list_layout_button_next"
        android:text="Next"
        android:textColor="@color/toolbar_bg_color"
        android:background="@color/color_gray_6"
        android:imeOptions="actionNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>